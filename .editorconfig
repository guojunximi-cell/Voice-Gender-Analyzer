# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{json,jsonc}]
indent_size = 2

[*.yaml]
indent_size = 2

[*.html]
indent_size = 2
indent_style = tab

[*.css]
indent_size = 2
indent_style = tab

[*.{js,ts,jsx,tsx}]
indent_size = 2
indent_style = tab
