# 复制为 .env 并按需修改，docker compose 会自动加载。
# 字段清单对应 voiceya/config.py 的 Settings。

# ── 必需 ──────────────────────────────────────────────────
# docker compose 下用服务名 redis；裸机部署改为实际地址。
REDIS_URL=redis://redis:6379/0

# ── 日志 ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── 限制与安全 ────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
MAX_AUDIO_DURATION_SEC=180
RATE_LIMIT_CT=10
RATE_LIMIT_DURATION_SEC=60

# ── 并发控制 ──────────────────────────────────────────────
MAX_CONCURRENT=2
MAX_QUEUE_DEPTH=30

# ── 任务 TTL（秒）─────────────────────────────────────────
TASK_MAX_EXEC_SEC=900
TASK_EVENTS_TTL_SEC=600
TASK_RESULT_TTL_SEC=600

# ── Engine C / 进阶分析（默认关）────────────────────────
# 开启前须同时起 visualizer-backend sidecar：
#   docker compose --profile engine-c up -d --build
# 失败/不可达时 summary.engine_c = null，主响应不受影响。
ENGINE_C_ENABLED=false
ENGINE_C_SIDECAR_URL=http://visualizer-backend:8001
ENGINE_C_SIDECAR_TIMEOUT_SEC=60
ENGINE_C_MIN_DURATION_SEC=3
# 共享密钥：留空则 sidecar 启动告警、不强制鉴权（仅 dev / docker 隔离内网）。
# 生产请设为强随机字符串，例如 `openssl rand -hex 32`。
# docker-compose 会同时注入到 worker (ENGINE_C_SIDECAR_TOKEN) 和
# sidecar (ENGINE_C_TOKEN)，所以这里只需配一次。
ENGINE_C_SIDECAR_TOKEN=
# Sidecar 单请求 audio 字节上限（MiB），防御内部 DoS。
ENGINE_C_MAX_AUDIO_MB=50
