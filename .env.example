# 复制为 .env 并按需修改，docker compose 会自动加载。
# 字段清单对应 voiceya/config.py 的 Settings。

# ── 必需 ──────────────────────────────────────────────────
# docker compose 下用服务名 redis；裸机部署改为实际地址。
REDIS_URL=redis://redis:6379/0

# ── 日志 ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── 限制与安全 ────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
MAX_AUDIO_DURATION_SEC=180
RATE_LIMIT_CT=10
RATE_LIMIT_DURATION_SEC=60

# ── 并发控制 ──────────────────────────────────────────────
MAX_CONCURRENT=2
MAX_QUEUE_DEPTH=30

# ── 任务 TTL（秒）─────────────────────────────────────────
TASK_MAX_EXEC_SEC=900
TASK_EVENTS_TTL_SEC=600
TASK_RESULT_TTL_SEC=600
